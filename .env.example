# ============================================================
# Incident Response Agent - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control!

# ─────────────────────────────────────────────────────────────
# MODEL PROVIDER SELECTION
# ─────────────────────────────────────────────────────────────
# Choose between "anthropic" or "watsonx"
MODEL_PROVIDER=anthropic

# ─────────────────────────────────────────────────────────────
# ANTHROPIC CONFIGURATION (if MODEL_PROVIDER=anthropic)
# ─────────────────────────────────────────────────────────────
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Model options:
# - anthropic:claude-haiku-4-5-20251001 (fast + cheap)
# - anthropic:claude-sonnet-4-5-20250929 (smarter)
ANTHROPIC_MODEL=anthropic:claude-haiku-4-5-20251001

# ─────────────────────────────────────────────────────────────
# IBM WATSONX CONFIGURATION (if MODEL_PROVIDER=watsonx)
# ─────────────────────────────────────────────────────────────
# WatsonX API credentials
WATSON_API_KEY=your-watson-api-key-here
WATSON_ML_URL=https://us-south.ml.cloud.ibm.com
WATSON_PROJECT_ID=your-watson-project-id-here

# Model options:
# - meta-llama/llama-3-3-70b-instruct
# - openai/gpt-oss-120b
WATSON_MODEL_ID=meta-llama/llama-3-3-70b-instruct

# WatsonX Model Parameters
WATSON_DECODING_METHOD=greedy
WATSON_TEMPERATURE=0.5
WATSON_MIN_NEW_TOKENS=5
WATSON_MAX_NEW_TOKENS=800

# ─────────────────────────────────────────────────────────────
# MCP SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────
# Configure your MCP (Model Context Protocol) server integration
# Leave MCP_SERVER_URL empty to disable MCP tools
# Example: Debug Assistant MCP Server for additional debugging capabilities
MCP_SERVER_NAME=any-mcp
MCP_SERVER_URL=<mcp-url>
MCP_SERVER_TRANSPORT=streamable-http

# ─────────────────────────────────────────────────────────────
# OPTIONAL: Additional MCP Servers
# ─────────────────────────────────────────────────────────────
# You can add more MCP servers by following the same pattern:
# MCP_SERVER_NAME_2=another-mcp-server
# MCP_SERVER_URL_2=https://another-server.example.com/mcp
# MCP_SERVER_TRANSPORT_2=streamable-http